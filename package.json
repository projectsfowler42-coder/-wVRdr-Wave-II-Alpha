{
  "name": "wvrdr-wave-ii-alpha-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "build": "pnpm -r --if-present run build",
    "dev:bridge": "bash scripts/dev-bridge.sh",
    "dev:cockpit": "bash scripts/dev-cockpit.sh",
    "check:local-proof": "bash scripts/check-local-proof.sh",
    "check:r3-imports": "node scripts/check-r3-nodenext-imports.mjs",
    "check:jenova-venice": "node scripts/check-jenova-venice-remediation.mjs",
    "test:r3": "pnpm check:jenova-venice && pnpm check:r3-imports && pnpm exec tsc -p tsconfig.r3.json && node .r3-build/tests/r3Engine.spec.js && node r3/tests/r3VaultCliSmoke.mjs",
    "audit:r3": "node r3/audit/r3-audit-loop.mjs",
    "vault:manifest": "pnpm exec tsc -p tsconfig.r3.json && node .r3-build/local-vault/make-manifest.js",
    "vault:repo-safe": "pnpm exec tsc -p tsconfig.r3.json && node .r3-build/local-vault/make-repo-safe-manifest.js"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
