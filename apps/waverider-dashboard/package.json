{
  "name": "@workspace/waverider-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "mdk:status": "node scripts/validate-mdk-status.mjs",
    "mdk:source": "node scripts/validate-dashboard-source.mjs",
    "mdk:snapshot": "node scripts/validate-dashboard-snapshot.mjs && node scripts/validate-dashboard-snapshot-fixtures.mjs",
    "mdk:docs": "node scripts/validate-dashboard-docs.mjs",
    "mdk:uiux": "node scripts/validate-dashboard-uiux-socom.mjs",
    "mdk:visual": "node scripts/validate-dashboard-visual-source.mjs",
    "mdk:static": "pnpm run mdk:status && pnpm run mdk:source && pnpm run mdk:snapshot && pnpm run mdk:docs && pnpm run mdk:uiux && pnpm run mdk:visual",
    "mdk:gate": "pnpm run typecheck && pnpm run build && pnpm run mdk:static"
  },
  "dependencies": {
    "@vitejs/plugin-react": "catalog:",
    "vite": "catalog:",
    "typescript": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "lucide-react": "catalog:"
  },
  "devDependencies": {}
}
