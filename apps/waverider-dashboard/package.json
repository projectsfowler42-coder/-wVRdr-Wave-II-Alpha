{
  "name": "@workspace/waverider-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "mdk:status": "node scripts/validate-mdk-status.mjs",
    "mdk:source": "node scripts/validate-dashboard-source.mjs",
    "mdk:snapshot": "node scripts/validate-dashboard-snapshot.mjs",
    "mdk:static": "pnpm run mdk:status && pnpm run mdk:source && pnpm run mdk:snapshot",
    "mdk:gate": "pnpm run typecheck && pnpm run build && pnpm run mdk:static"
  },
  "dependencies": {
    "@vitejs/plugin-react": "catalog:",
    "vite": "catalog:",
    "typescript": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "lucide-react": "catalog:"
  },
  "devDependencies": {}
}
